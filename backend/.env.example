# Copy to .env for local dev, or set these as environment variables on your host.
# NEVER commit the real .env — it is gitignored.

# --- Database (MongoDB Atlas) ---
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=Cluster0
DB_NAME=lumina_interview

# --- AI (Groq) — get a key at https://console.groq.com ---
GROQ_API_KEY=gsk_your_key_here

# --- Auth ---
JWT_SECRET=change-this-to-a-long-random-string

# --- Google OAuth (optional; leave blank to disable "Continue with Google") ---
# Add the production callback in Google Cloud Console:
#   https://<your-backend-domain>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- URLs / CORS ---
# In production set these to your real deployed domains (comma-separated for CORS).
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# --- Misc ---
APP_NAME=lumina-interview
UPLOAD_DIR=./uploads
